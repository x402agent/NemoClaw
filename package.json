{
  "name": "nemoclaw",
  "version": "0.1.0",
  "description": "NemoClaw — run OpenClaw inside OpenShell with NVIDIA inference",
  "license": "Apache-2.0",
  "bin": {
    "nemoclaw": "./bin/nemoclaw.js"
  },
  "scripts": {
    "test": "node --test test/*.test.js",
    "prepublishOnly": "cd nemoclaw && npm install --ignore-scripts && npm run build"
  },
  "dependencies": {
    "@img/sharp-darwin-arm64": "^0.34.5",
    "openclaw": "2026.3.11"
  },
  "files": [
    "bin/",
    "nemoclaw/dist/",
    "nemoclaw/openclaw.plugin.json",
    "nemoclaw/package.json",
    "nemoclaw-blueprint/",
    "Pump-Fun/src/",
    "Pump-Fun/agent-app/",
    "Pump-Fun/agent-tasks/",
    "Pump-Fun/docs/",
    "Pump-Fun/packages/defi-agents/",
    "Pump-Fun/pumpkit/agent-prompts/",
    "Pump-Fun/telegram-bot/",
    "Pump-Fun/swarm-bot/",
    "Pump-Fun/websocket-server/",
    "Pump-Fun/tools/",
    "Pump-Fun/x402/",
    "pump-fun-skills-main/tokenized-agents/",
    "scripts/",
    "Dockerfile",
    ".dockerignore"
  ],
  "engines": {
    "node": ">=20.0.0"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/NVIDIA/NemoClaw.git"
  }
