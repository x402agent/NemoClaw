{
  "name": "@mawdbotsonsolana/nemoclaw",
  "version": "0.4.1",
  "description": "NemoClaw — autonomous Solana trading agent with Pump-Fun SDK, Privy agentic wallets, and natural-language Telegram bridge. One command to deploy.",
  "license": "Apache-2.0",
  "keywords": [
    "solana",
    "pump-fun",
    "trading-bot",
    "telegram-bot",
    "agentic-wallet",
    "privy",
    "openclaw",
    "openshell",
    "nvidia",
    "ai-agent",
    "defi",
    "autonomous-agent",
    "ollama",
    "deepsolana"
  ],
  "bin": {
    "nemoclaw": "bin/nemoclaw.js"
  },
  "scripts": {
    "test": "node --test test/*.test.js",
    "build:plugin": "npm --prefix nemoclaw run build",
    "public:audit": "bash scripts/public-release-audit.sh",
    "pack:check": "npm pack --dry-run --cache /tmp/nemoclaw-npm-cache",
    "release:check": "npm run build:plugin && npm test && npm run public:audit && npm run pack:check",
    "publish:public": "npm publish --access public",
    "prepublishOnly": "npm run build:plugin && npm test"
  },
  "dependencies": {
    "openclaw": "2026.3.11"
  },
  "files": [
    "bin/",
    "SKILL.md",
    "nemoclaw/dist/",
    "nemoclaw/openclaw.plugin.json",
    "nemoclaw/package.json",
    "nemoclaw-blueprint/",
    "Pump-Fun/src/",
    "Pump-Fun/agent-app/",
    "Pump-Fun/agent-tasks/",
    "Pump-Fun/docs/",
    "Pump-Fun/packages/defi-agents/",
    "Pump-Fun/pumpkit/",
    "Pump-Fun/pumpkit/agent-prompts/",
    "Pump-Fun/pumpkit/tutorials/",
    "Pump-Fun/telegram-bot/",
    "Pump-Fun/swarm-bot/",
    "Pump-Fun/websocket-server/",
    "Pump-Fun/tools/",
    "Pump-Fun/x402/",
    "pump-fun-skills-main/tokenized-agents/",
    "scripts/brev-setup.sh",
    "scripts/fix-coredns.sh",
    "scripts/install-openshell.sh",
    "scripts/install.sh",
    "scripts/nemoclaw-payment-app.sh",
    "scripts/nemoclaw-solana-agent.sh",
    "scripts/nemoclaw-solana-bridge.sh",
    "scripts/nemoclaw-solana-stack.sh",
    "scripts/nemoclaw-start.sh",
    "scripts/nemoclaw-swarm-bot.sh",
    "scripts/nemoclaw-telegram-bot.sh",
    "scripts/nemoclaw-websocket-server.sh",
    "scripts/pre-commit-secrets.sh",
    "scripts/public-release-audit.sh",
    "scripts/setup-spark.sh",
    "scripts/setup.sh",
    "scripts/start-services.sh",
    "scripts/telegram-bridge.js",
    "scripts/test-inference-local.sh",
    "scripts/test-inference.sh",
    "scripts/walkthrough.sh",
    "scripts/write-auth-profile.py",
    "Dockerfile",
    ".dockerignore"
  ],
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org/"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/x402agent/NemoClaw.git"
  },
  "homepage": "https://nemo.nanosolana.com",
  "bugs": {
    "url": "https://github.com/x402agent/NemoClaw/issues"
  }
}
