{
  "name": "@mawdbotsonsolana/nemoclaw",
  "version": "0.2.0",
  "description": "NemoClaw — autonomous Solana trading agent with Pump-Fun SDK, Privy agentic wallets, and natural-language Telegram bridge. One command to deploy.",
  "license": "Apache-2.0",
  "keywords": [
    "solana",
    "pump-fun",
    "trading-bot",
    "telegram-bot",
    "agentic-wallet",
    "privy",
    "openclaw",
    "openshell",
    "nvidia",
    "ai-agent",
    "defi",
    "autonomous-agent"
  ],
  "bin": {
    "nemoclaw": "./bin/nemoclaw.js"
  },
  "scripts": {
    "test": "node --test test/*.test.js",
    "prepublishOnly": "cd nemoclaw && npm install --ignore-scripts && npm run build"
  },
  "dependencies": {
    "openclaw": "2026.3.11"
  },
  "files": [
    "bin/",
    "nemoclaw/dist/",
    "nemoclaw/openclaw.plugin.json",
    "nemoclaw/package.json",
    "nemoclaw-blueprint/",
    "Pump-Fun/src/",
    "Pump-Fun/agent-app/",
    "Pump-Fun/agent-tasks/",
    "Pump-Fun/docs/",
    "Pump-Fun/packages/defi-agents/",
    "Pump-Fun/pumpkit/",
    "Pump-Fun/pumpkit/agent-prompts/",
    "Pump-Fun/pumpkit/tutorials/",
    "Pump-Fun/telegram-bot/",
    "Pump-Fun/swarm-bot/",
    "Pump-Fun/websocket-server/",
    "Pump-Fun/tools/",
    "Pump-Fun/x402/",
    "pump-fun-skills-main/tokenized-agents/",
    "scripts/",
    "Dockerfile",
    ".dockerignore"
  ],
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org/"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/NVIDIA/NemoClaw.git"
  }
}
