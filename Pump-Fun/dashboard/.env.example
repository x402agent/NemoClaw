# Dashboard — Environment Variables
# Copy to .env and fill in your values

# ─── Server ─────────────────────────────────────────────────
DASHBOARD_PORT=8080
DASHBOARD_API_KEY=your_api_key_here

# ─── Bot Service Endpoints ──────────────────────────────────
TELEGRAM_BOT_URL=http://localhost:3000
CHANNEL_BOT_URL=http://localhost:3002
OUTSIDERS_BOT_URL=http://localhost:3001
WEBSOCKET_SERVER_URL=http://localhost:3003

# ─── Telegram Bot API (for direct control) ──────────────────
TELEGRAM_BOT_API_KEY=your_bot_token_here
TELEGRAM_BOT_ENABLE_API=false

# ─── Solana RPC ─────────────────────────────────────────────
SOLANA_RPC_URL=https://api.mainnet-beta.solana.com
